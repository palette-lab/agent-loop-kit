{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-loop-kit.dev/schemas/loop.schema.json",
  "title": "Agent Loop Kit Loop",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "category",
    "summary",
    "tags",
    "useCases",
    "riskLevel",
    "inputs",
    "steps",
    "checks",
    "stopConditions",
    "evidence",
    "humanApproval",
    "compatibleAgents",
    "prompt",
    "version",
    "updated",
    "author",
    "license"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "category": {
      "type": "string",
      "enum": [
        "agent",
        "content",
        "data",
        "design",
        "engineering",
        "evaluation",
        "operations",
        "product",
        "security"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "useCases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "stopConditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "humanApproval": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "compatibleAgents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 100
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    }
  }
}
